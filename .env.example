# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Admin panel (/admin and /send) — required for those routes to work at all.
# Pick your own values; these are NOT provided for you.
ADMIN_USER=admin
ADMIN_PASS=change_me_to_something_strong

# Twilio webhook signature validation — leave true except for local debugging
# without a real Twilio-signed request.
TWILIO_VALIDATE_SIGNATURE=true

# Max inbound messages processed per WhatsApp number per hour.
RATE_LIMIT_PER_HOUR=20
